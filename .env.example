# Web
MEDIA_STUDIO_APP_ENV=development
NEXT_PUBLIC_MEDIA_STUDIO_CONTROL_API_BASE_URL=http://127.0.0.1:8000
MEDIA_STUDIO_CONTROL_API_BASE_URL=http://127.0.0.1:8000
# Internal web->API token. Keep the same value for both the Next app and FastAPI.
# Generate a unique random value for your machine or deployment.
MEDIA_STUDIO_CONTROL_API_TOKEN=replace_with_a_unique_control_token
# Optional: set both values if you want browser auth outside strict localhost-only use.
MEDIA_STUDIO_ADMIN_USERNAME=
MEDIA_STUDIO_ADMIN_PASSWORD=
# Optional: allow access from private LAN / TailScale addresses without browser auth.
MEDIA_STUDIO_ALLOW_PRIVATE_NETWORK_ACCESS=false

# API
MEDIA_STUDIO_API_HOST=127.0.0.1
MEDIA_STUDIO_API_PORT=8000
MEDIA_STUDIO_DB_PATH=/absolute/path/to/media-studio/data/media-studio.db
MEDIA_STUDIO_DATA_ROOT=/absolute/path/to/media-studio/data
MEDIA_STUDIO_KIE_API_REPO_PATH=/absolute/path/to/kie-api
MEDIA_STUDIO_SUPERVISOR=manual
# Required for live submits after you get your key:
# https://kie.ai?ref=e7565cf24a7fad4586341a87eaf21e42
MEDIA_ENABLE_LIVE_SUBMIT=false
MEDIA_BACKGROUND_POLL_ENABLED=true
MEDIA_POLL_SECONDS=6
MEDIA_PRICING_CACHE_HOURS=6
KIE_API_KEY=your_kie_api_key_here

# Optional prompt enhancement providers
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MEDIA_LOCAL_OPENAI_BASE_URL=http://127.0.0.1:8080/v1
MEDIA_LOCAL_OPENAI_API_KEY=
