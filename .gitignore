.DS_Store

# Local environment and developer overrides
.env
.env.*
!.env.example
.env.local
.env.*.local
.envrc
.direnv/
*.local

# Python / Node build output
.venv/
.python-version
node_modules/
.next/
dist/
build/
coverage/
pytest_cache/
.pytest_cache/
__pycache__/
*.pyc
*.pyo
*.pyd

# Runtime databases and sidecar files
# `data/` is persistent local Studio state: user media, references, thumbs, DBs, logs.
# Never commit it and never treat it as disposable during repo syncs.
data/
data/*.db
data/*.sqlite
data/*.sqlite3
data/*.db-wal
data/*.db-shm
data/*.sqlite-wal
data/*.sqlite-shm
data/uploads/
data/downloads/
data/outputs/
data/reference-media/
data/runtime/
data/preset-thumbnails/
data/*.jsonl
data/backups/

# Local artifacts, temp files, and process output
# `temp/local-smoke/` is the home for developer-only smoke helpers that should never be tracked.
.playwright-cli/
artifacts/
logs/
tmp/
temp/
output/
*.log
*.pid
*.pid.lock

# Local credentials and certificates
*.pem
*.key
*.crt
*.cer
*.p12

apps/api/.mypy_cache/
apps/api/.ruff_cache/
apps/api/*.egg-info/
apps/web/.turbo/
apps/web/tsconfig.tsbuildinfo
