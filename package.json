{
  "name": "media-studio",
  "private": true,
  "version": "1.0.1",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "setup:mac": "./scripts/onboard_mac.sh",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File .\\scripts\\onboard_windows.ps1",
    "setup:linux": "./scripts/onboard_linux.sh",
    "setup:shared-env": "./scripts/setup_shared_env.sh",
    "generate:api-specs": "./scripts/with_shared_python.sh ./scripts/generate_api_specs.py",
    "quality": "./scripts/run-quality-gates",
    "release:verify": "./scripts/run-release-gates",
    "db:backup": "./scripts/backup_db.sh",
    "db:migration-status": "./scripts/migration_status.sh",
    "db:clean": "./scripts/create_clean_db.sh --output ./data/backups/media-studio-clean.sqlite --overwrite",
    "start:api": "node ./scripts/dev_api.mjs --no-reload",
    "dev:api": "node ./scripts/dev_api.mjs",
    "dev:web": "npm --workspace apps/web run dev",
    "start:web": "npm --workspace apps/web run start",
    "build": "npm run build:web",
    "dev": "node ./scripts/run_studio.mjs",
    "start": "npm run start:studio",
    "start:studio": "node ./scripts/run_studio.mjs --production --open",
    "start:studio:linux": "./scripts/run_studio_linux.sh",
    "start:studio:windows": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run_studio.ps1",
    "stop:studio": "node ./scripts/stop_studio.mjs",
    "stop:studio:linux": "./scripts/stop_studio_linux.sh",
    "stop:studio:windows": "powershell -ExecutionPolicy Bypass -File .\\scripts\\stop_studio.ps1",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint",
    "typecheck:web": "npm --workspace apps/web run typecheck",
    "smoke:studio": "node ./scripts/smoke_studio_playwright.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "vitest": "^3.2.4"
  }
}
