{
  "name": "media-studio",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "setup:mac": "./scripts/onboard_mac.sh",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File .\\scripts\\onboard_windows.ps1",
    "setup:shared-env": "./scripts/setup_shared_env.sh",
    "review:scaffold": "./scripts/scaffold_review_outputs.sh",
    "generate:api-specs": "./scripts/with_shared_python.sh ./scripts/generate_api_specs.py",
    "audit:api-security": "./scripts/with_shared_python.sh ./scripts/audit_api_security.py",
    "quality": "./scripts/run-quality-gates",
    "release:verify": "./scripts/run-release-gates",
    "smoke:studio-browser": "node ./scripts/studio_browser_smoke.mjs",
    "smoke:studio-browser-seedance": "node ./scripts/studio_browser_seedance_smoke.mjs",
    "smoke:studio-browser-preset": "node ./scripts/studio_browser_preset_smoke.mjs",
    "smoke:studio-browser-enhance": "node ./scripts/studio_browser_enhance_smoke.mjs",
    "smoke:studio-browser-retry": "node ./scripts/studio_browser_retry_restore_smoke.mjs",
    "smoke:studio-browser-reference-backfill": "node ./scripts/studio_browser_reference_backfill_smoke.mjs",
    "smoke:studio-live": "node ./scripts/studio_live_smoke.mjs",
    "db:backup": "./scripts/backup_db.sh",
    "db:clean": "./scripts/create_clean_db.sh --output ./data/backups/media-studio-clean.sqlite --overwrite",
    "start:api": "./scripts/start_api.sh",
    "dev:api": "./scripts/dev_api.sh",
    "dev:web": "npm --workspace apps/web run dev",
    "start:web": "npm --workspace apps/web run start",
    "build": "npm run build:web",
    "dev": "npm run dev:web",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint",
    "typecheck:web": "npm --workspace apps/web run typecheck"
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "vitest": "^3.2.4"
  }
}
