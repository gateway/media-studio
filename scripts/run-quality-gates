#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="${MEDIA_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
DEFAULT_KIE_ROOT="$ROOT/../kie-api"
LEGACY_KIE_ROOT="$ROOT/../kie-ai/kie_codex_bootstrap"
if [[ -d "$DEFAULT_KIE_ROOT" ]]; then
  KIE_ROOT="${KIE_ROOT:-${MEDIA_STUDIO_KIE_API_REPO_PATH:-$DEFAULT_KIE_ROOT}}"
else
  KIE_ROOT="${KIE_ROOT:-${MEDIA_STUDIO_KIE_API_REPO_PATH:-$LEGACY_KIE_ROOT}}"
fi
VENV_PY="$KIE_ROOT/.venv/bin/python"

"$VENV_PY" "$ROOT/scripts/check_repo_hygiene.py"

MEDIA_STUDIO_DB_PATH="${MEDIA_STUDIO_DB_PATH:-$ROOT/data/media-studio.db}" \
MEDIA_STUDIO_DATA_ROOT="${MEDIA_STUDIO_DATA_ROOT:-$ROOT/data}" \
MEDIA_STUDIO_KIE_API_REPO_PATH="${MEDIA_STUDIO_KIE_API_REPO_PATH:-$KIE_ROOT}" \
"$VENV_PY" -m pytest -q "$ROOT/apps/api/tests"

cd "$ROOT"
npm --workspace apps/web run test
npm --workspace apps/web run typecheck
npm --workspace apps/web run build
