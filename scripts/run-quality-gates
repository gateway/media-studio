#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/shared_env.sh
. "$SCRIPT_DIR/shared_env.sh"
ROOT="${MEDIA_ROOT:-$(media_root_from_script "${BASH_SOURCE[0]}")}"
load_media_env "$ROOT"
KIE_ROOT="$(resolve_kie_root "$ROOT")"
VENV_PY="$KIE_ROOT/.venv/bin/python"
VENV_PIP="$KIE_ROOT/.venv/bin/pip"

"$VENV_PY" "$ROOT/scripts/check_repo_hygiene.py"

"$VENV_PIP" install -q -e "$ROOT/apps/api[dev]"

(
  cd "$ROOT/apps/api"
  MEDIA_STUDIO_DB_PATH="${MEDIA_STUDIO_DB_PATH:-$ROOT/data/media-studio.db}" \
  MEDIA_STUDIO_DATA_ROOT="${MEDIA_STUDIO_DATA_ROOT:-$ROOT/data}" \
  MEDIA_STUDIO_KIE_API_REPO_PATH="${MEDIA_STUDIO_KIE_API_REPO_PATH:-$KIE_ROOT}" \
  "$VENV_PY" -m pytest -q tests
)

cd "$ROOT"
npm --workspace apps/web run test
npm --workspace apps/web run lint
npm --workspace apps/web run typecheck
npm --workspace apps/web run build
